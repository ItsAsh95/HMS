<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>HMS - Patients</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: Arial, sans-serif; margin: 0; padding-top: 70px; padding-bottom: 60px; background-color: #f4f4f4; }
        header { background-color: #000; color: white; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; position: fixed; top: 0; width: 100%; z-index: 1000; }
        header h1 { margin: 0; font-size: 1.5rem; }
        .logout-btn { background-color: #dc3545; color: white; padding: 8px 15px; border-radius: 4px; text-decoration: none; }
        main { padding: 20px; }
        footer { background-color: #000; color: white; text-align: center; padding: 10px; position: fixed; bottom: 0; width: 100%; }
    </style>
</head>
<body>
    <header>
        <h1>HMS - Patients</h1>
        <a href="/logout" class="logout-btn">Logout</a>
    </header>

    <main>
        <table class="table table-bordered table-striped table-hover bg-white">
            <thead class="table-dark">
                <tr>
                    <th>Patient ID</th>
                    <th>Name</th>
                    <th>DOB</th>
                    <th>Address</th>
                    <th>Contact</th>
                    <th>Insurance</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (patients && patients.length > 0) { %>
                    <% patients.forEach(patient => { %>
                        <tr>
                            <td><%= patient.patient_id %></td>
                            <td><%= patient.name %></td>
                            <td><%= patient.dob ? new Date(patient.dob).toLocaleDateString() : 'N/A' %></td>
                            <td><%= patient.address %></td>
                            <td><%= patient.contact_details %></td>
                            <td><%= patient.insurance_details || 'N/A' %></td>
                            <td>
                                <button class="btn btn-danger btn-sm delete-btn" 
                                        data-id="<%= patient.patient_id %>" 
                                        data-type="patients">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="7" class="text-center">No patients found</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </main>

    <footer>
        © 2025 Hospital Management System. All rights reserved.
    </footer>

    <script src="/js/delete.js"></script>
</body>
</html>