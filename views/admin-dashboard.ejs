<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - HMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="/admin-dashboard">HMS (Admin)</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"><span class="navbar-toggler-icon"></span></button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link active" href="/admin-dashboard">Home</a></li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">View Database</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/appointments">Appointments</a></li>
                                <li><a class="dropdown-item" href="/patients">Patients</a></li>
                                <li><a class="dropdown-item" href="/doctors">Doctors</a></li>
                                <li><a class="dropdown-item" href="/billing">Billing</a></li>
                                <li><a class="dropdown-item" href="/diagnostics">Diagnostics</a></li>
                            </ul>
                        </li>
                    </ul>
                    <span class="navbar-text me-3 text-white-50">Welcome, <%= username %></span>
                    <a class="btn btn-danger" href="/logout">Logout</a>
                </div>
            </div>
        </nav>
    </header>

    <main>
        <div class="container py-5">
            <div class="p-5 mb-4 rounded-3 dashboard-jumbotron">
                <div class="container-fluid py-4">
                    <h1 class="display-5 fw-bold">Administrator Dashboard</h1>
                    <p class="col-md-8 fs-4">Full access to all system management tools and data views.</p>
                </div>
            </div>
        </div>
        
        <section class="features pt-0">
            <h2 class="text-center mb-4">Management Tools</h2>
            <div class="features-grid">
                
                <a href="/booking-form" class="feature-box"><h3><i class="bi bi-calendar-plus-fill me-2"></i>Book Appointment</h3><p>Schedule new appointments for patients.</p></a>
                <a href="/patient-form" class="feature-box"><h3><i class="bi bi-person-plus-fill me-2"></i>Patient Management</h3><p>Register new patients into the system.</p></a>
                <a href="/doctor-form" class="feature-box"><h3><i class="bi bi-person-badge me-2"></i>Doctor Tools</h3><p>Add new doctors or update their details.</p></a>
                <a href="/billing-form" class="feature-box"><h3><i class="bi bi-receipt-cutoff me-2"></i>Billing & Payments</h3><p>Create new billing records for services rendered.</p></a>
                <a href="/diagnostics-form" class="feature-box"><h3><i class="bi bi-clipboard2-pulse-fill me-2"></i>Schedule Diagnostic</h3><p>Book diagnostic tests for patients.</p></a>
            </div>
        </section>
    </main>

    <footer class="mt-auto">
        <div class="container">© 2025 Hospital Management System. All rights reserved. | <a href="/about">About This Project</a></div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>