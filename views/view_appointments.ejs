<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>HMS - Appointments</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { font-family: Arial, sans-serif; margin: 0; padding-top: 70px; padding-bottom: 60px; background-color: #f4f4f4; }
    header { background-color: #000; color: white; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; position: fixed; top: 0; width: 100%; z-index: 1000; }
    header h1 { margin: 0; font-size: 1.5rem; }
    .logout-btn { background-color: #dc3545; color: white; padding: 8px 15px; border-radius: 4px; text-decoration: none; }
    main { padding: 20px; }
    footer { background-color: #000; color: white; text-align: center; padding: 10px; position: fixed; bottom: 0; width: 100%; }
  </style>
</head>
<body>
    <header>
        <h1>HMS - Appointments</h1>
        <a href="/logout" class="logout-btn">Logout</a>
    </header>

  <main>
    <table class="table table-bordered table-striped table-hover bg-white">
      <thead class="table-dark">
        <tr>
          <th>ID</th>
          <th>Patient ID</th>
          <th>Doctor ID</th>
          <th>Date</th>
          <th>Time</th>
          <th>Reason</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% appointments.forEach(appointment => { %>
          <tr>
            <td><%= appointment.appointment_id %></td>
            <td><%= appointment.patient_id %></td>
            <td><%= appointment.doctor_id %></td>
            <td><%= new Date(appointment.date).toLocaleDateString() %></td>
            <td><%= appointment.time %></td>
            <td><%= appointment.reason || 'N/A' %></td>
            <td>
              <button class="btn btn-danger btn-sm delete-btn" 
                      data-id="<%= appointment.appointment_id %>" 
                      data-type="appointments">
                Delete
              </button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </main>

  <footer>
      © 2025 Hospital Management System. All rights reserved.
  </footer>

  <script src="/js/delete.js"></script>
</body>
</html>