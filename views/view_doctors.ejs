<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>HMS - Doctors</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { font-family: Arial, sans-serif; margin: 0; padding-top: 70px; padding-bottom: 60px; background-color: #f4f4f4; }
    header { background-color: #000; color: white; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; position: fixed; top: 0; width: 100%; z-index: 1000; }
    header h1 { margin: 0; font-size: 1.5rem; }
    .logout-btn { background-color: #dc3545; color: white; padding: 8px 15px; border-radius: 4px; text-decoration: none; }
    main { padding: 20px; }
    footer { background-color: #000; color: white; text-align: center; padding: 10px; position: fixed; bottom: 0; width: 100%; }
    .schedule-summary { font-style: italic; color: #6c757d; }
  </style>
</head>
<body>
  <header>
      <h1>HMS - Doctors</h1>
      <a href="/logout" class="logout-btn">Logout</a>
  </header>

  <main>
    <table class="table table-bordered table-striped table-hover bg-white">
      <thead class="table-dark">
        <tr>
          <th>Doctor ID</th>
          <th>Name</th>
          <th>Specialty</th>
          <th>Contact</th>
          <th>Department</th>
          
          <th>Working Days</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% doctors.forEach(doctor => { %>
          <tr>
            <td><%= doctor.doctor_id %></td>
            <td><%= doctor.name %></td>
            <td><%= doctor.specialty %></td>
            <td><%= doctor.contact_details %></td>
            <td><%= doctor.department %></td>
            
            <td class="schedule-summary">
              <%= doctor.schedule_summary || 'No schedule set' %>
            </td>
            <td>
              <button class="btn btn-danger btn-sm delete-btn" data-id="<%= doctor.doctor_id %>" data-type="doctors">Delete</button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </main>

  <footer>© 2025 Hospital Management System. All rights reserved.</footer>
  <script src="/js/delete.js"></script>
</body>
</html>